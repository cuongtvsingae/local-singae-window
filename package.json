{
  "name": "singae-local",
  "version": "1.0.0",
  "description": "Local tools hub + chatbot engine (LLM on LAN)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "setup": "node ./scripts/bootstrap.js",
    "chatbot-local:server": "node chatbot/chatbot-server.js",
    "chatbot-local:processor": "node chatbot/local-processor.js",
    "chatbot-local:worker": "node chatbot/worker.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 delete ecosystem.config.cjs 2>nul & pm2 start ecosystem.config.cjs",
    "pm2:reset": "pm2 delete ecosystem.config.cjs 2>nul & pm2 kill 2>nul",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "kb:import-faq-json": "node chatbot/scripts/import-knowledge-rang-su-faq.cjs"
  },
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.6",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "eventsource": "^2.0.2",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.8.0",
    "multer": "^2.0.2",
    "openai": "^4.104.0",
    "pdf-parse": "^1.1.1",
    "sqlite3": "^5.1.7",
    "vietnam-address-database": "^1.0.0",
    "xlsx": "^0.18.5",
    "zca-js": "^2.1.2"
  }
}
