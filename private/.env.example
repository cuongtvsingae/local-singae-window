# Copy → private/.env on your dev machine

PORT=3000
LISTEN_HOST=0.0.0.0

# VPS Simly (no SIMLY_API_KEY_* needed locally)
SIMLY_PUBLIC_BASE_URL=https://singae.cloud
SIMLY_PUBLIC_TOKENS_URL=https://singae.cloud/api/public/tokens

# Chatbot engine + worker
CHATBOT_MANAGER_BASE_URL=https://singae.cloud/api/chatbot-manager
CHATBOT_LOCAL_SERVER_PORT=13001
CHATBOT_LOCAL_PROCESS_PORT=13000
CHATBOT_LOCAL_FORWARD_URL=http://127.0.0.1:13001/webhooks/chatbot/facebook
CHATBOT_LOCAL_RETRY_MS=3000

# Facebook (OAuth chạy trên VPS — xem vps/private/.env)
FB_VERIFY_TOKEN=
FACEBOOK_VERIFY_TOKEN=
FB_PAGE_ACCESS_TOKEN=

USE_VPS_FB_BRIDGE=1
BRIDGE_SEND_URL=https://singae.cloud/api/chatbot-bridge/facebook/send
# BRIDGE_SHARED_SECRET=

# LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Prompt: 1=compact (rulesHub+cases.compact), 0=legacy chatCases monolith
USE_COMPACT_PROMPT=1
# DEBUG_INTAKE_JSON=1
# Neu OpenAI tra 403 "Country not supported": VPN hoac relay (base URL OpenAI-compatible)
# OPENAI_BASE_URL=https://your-openai-proxy.example/v1

# Commission settings DB (local simlyTokenAdmin — no token refresh)
SKIP_SIMLY_TOKEN_REFRESH=1
